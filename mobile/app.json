{
  "expo": {
    "name": "Fressh",
    "slug": "fressh-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fressh",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.caritos.fressh",
      "buildNumber": "2",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-dev-launcher",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25e1f438-3c70-4c94-aba6-dab8ddf6a780"
      }
    },
    "owner": "sotirac"
  }
}
